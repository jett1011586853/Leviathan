# Anthropic-compatible provider credentials
ANTHROPIC_BASE_URL=https://token-plan-cn.example.com/anthropic
ANTHROPIC_AUTH_TOKEN=your-provider-token

# Provider model ID
ANTHROPIC_MODEL=mimo-v2.5

# Optional: separate small/fast model. Defaults to ANTHROPIC_MODEL when unset.
# ANTHROPIC_SMALL_FAST_MODEL=mimo-v2.5

# Optional: custom gateways do not receive automatic Leviathan/Anthropic beta
# headers by default. Enable provider betas only if your endpoint supports them.
# LEVIATHAN_CODE_ENABLE_PROVIDER_BETAS=true
# ANTHROPIC_BETAS=your-provider-beta-1,your-provider-beta-2
